{
  "name": "annealmusic",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "version": "6.1.0",
  "type": "module",
  "description": "A generative ambient meditation sandbox: physics-driven sound, session arc, and audio-reactive visuals.",
  "scripts": {
    "dev": "vite",
    "build:worklets": "vite build --config vite.worklet.config.ts",
    "build": "npm run build:worklets && tsc -b && vite build",
    "build:mobile": "npm run build:worklets && tsc -b && vite build --config vite.config.mobile.ts",
    "build:research": "npm run build:worklets && vite build --config vite.config.research.ts",
    "build:learn": "npm run build:worklets && vite build --config vite.config.learn.ts",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gen:schema": "vite-node schema/gen-manifest.ts",
    "gen:sources": "vite-node scripts/gen-sources.ts",
    "check:embed-size": "node scripts/check-embed-bundle.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@codemirror/lang-python": "^6.2.1",
    "@tonejs/midi": "^2.0.28",
    "@uiw/react-codemirror": "^4.25.10",
    "lucide-react": "^0.469.0",
    "ogl": "^1.0.11",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "y-webrtc": "^10.3.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^8.57.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.17.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1",
    "vite": "^5.4.11",
    "vite-node": "^2.1.8",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
