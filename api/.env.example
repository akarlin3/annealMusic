# Copy to .env for local runs without docker-compose. The compose file sets
# these directly; Railway sets them as service variables (see docs/DEPLOY.md).

ENV=dev

# Async SQLAlchemy URL. Local Postgres:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/annealmusic

# CORS allow-list (JSON array of exact origins).
CORS_ORIGINS=["http://localhost:5173"]

# Object storage. "memory" needs no S3 (good for quick local runs); "s3"
# targets MinIO locally or Cloudflare R2 in prod.
STORAGE_BACKEND=memory
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=annealmusic
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# WAV->Opus transcode needs ffmpeg on PATH; leave false if absent.
TRANSCODE_ENABLED=false
OPUS_BITRATE_KBPS=96

# Anon-id recovery cookie.
ANON_COOKIE_SECURE=false

# --- v0.8 gallery ---
# Moderation: comma-separated terms appended to the static list in app/moderation.py.
MODERATION_EXTRA_TERMS=
# Admin panel key. Unset => /admin endpoints disabled (404).
# ADMIN_KEY=

# Server-side preview rendering (headless Chromium). Needs Chromium on the host
# (the Dockerfile installs it) and the web build's harness reachable.
RENDER_ENABLED=false
RENDER_CONCURRENCY=2
PREVIEW_DURATION_SEC=20
PREVIEW_BITRATE_KBPS=96
# Where the render harness is served (web build emits /render.html).
RENDER_HARNESS_URL=http://localhost:5173/render.html

# Observability (no-op when unset).
# SENTRY_DSN=
